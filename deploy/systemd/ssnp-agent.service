[Unit]
Description=SSNP Agent Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ssnp-agent
Group=ssnp-agent
WorkingDirectory=/opt/ssnp-agent
ExecStart=/opt/ssnp-agent/.venv/bin/ssnp-agent --config /etc/ssnp-agent/config.yaml run
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/ssnp-agent /var/lib/ssnp-agent
StateDirectory=ssnp-agent

[Install]
WantedBy=multi-user.target
